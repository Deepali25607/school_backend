# Dependencies
node_modules/
.pnp
.pnp.js

# Runtime data (regenerated from data/seed.js on first boot — never commit)
# Contains: bcrypt password hashes, audit log, user PII, notification log, etc.
db/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment (real secrets live here — never commit)
.env
.env.*
!.env.example

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# Build output (none for this backend, but just in case)
dist/
build/
coverage/
.nyc_output/

# Misc
*.pid
*.seed
*.pid.lock
